{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Times Table Flashcards",
  "version": "0.1.0",
  "identifier": "com.imbue.flashcards",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Times Table Flashcards",
        "width": 1200,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["flashcards_sqlite"],
        "name": "Times Table Flashcards Database",
        "description": "Times Table Flashcards SQLite database",
        "role": "Editor"
      }
    ]
  }
}
